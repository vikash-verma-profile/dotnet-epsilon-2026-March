@model IEnumerable<Students>
@{
    ViewData["Title"] = "StudentList";
}

<table class="table">
    <thead class="table-dark">
        <tr>
            <th scope="col">Name</th>
            <th scope="col">Gender</th>
            <th scope="col">Age</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Gender</td>
                <td>@item.Age</td>
            </tr>
        }
       
    </tbody>
</table>

